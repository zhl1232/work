# Supabase 配置
# 从 Supabase Dashboard 获取这些值: https://app.supabase.com/project/_/settings/api

# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# Supabase 匿名公钥 (Anon Key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 注意：应用启动时会严格校验以上两个变量；
# 本地开发、CI 与 Cloudflare Worker 都需要提供。

# 数据库密码（仅用于 CLI 执行 db push 等，不要提交）
# 在 Dashboard → Project Settings → Database 查看或重置
# SUPABASE_DB_PASSWORD=your-database-password

# 可选配置
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 短信验证码（可选）
# 配置下面两个即走阿里云，签名/模板在代码内写死
# SMS_ALIYUN_ACCESS_KEY_ID=
# SMS_ALIYUN_ACCESS_KEY_SECRET=
# 自定义 HTTP 发短信（未配阿里云且需发短信时）：SMS_PROVIDER=custom、SMS_CUSTOM_URL=
